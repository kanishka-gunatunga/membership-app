{%- liquid
  comment
    Shared member pricing display.
    @param product {Product} required unless line_item is passed
    @param variant {Variant} optional
    @param line_item {LineItem} optional — used for cart layouts
    @param layout {String} pdp | card | cart-line
    @param member_label {String}
    @param rrp_label {String}
    @param membership_label {String}
    @param login_prompt {String}
    @param block_id {String} optional — used for PDP variant switching
    @param shopify_attributes {String} optional
  endcomment

  if line_item != blank
    assign mp_product = line_item.product
    assign mp_variant = line_item.variant
    assign mp_quantity = line_item.quantity
  else
    assign mp_product = product
    assign mp_variant = variant | default: product.selected_or_first_available_variant
  endif

  assign mp_storefront_raw = shop.metafields['$app'].storefront_config.value
  if mp_storefront_raw == blank
    assign mp_storefront_raw = shop.metafields.app.storefront_config.value
  endif

  assign mp_metafield_source = 'app'
  assign mp_product_handle = 'custom.member_price'
  assign mp_variant_handle = 'custom.variant_member_price'
  assign mp_campaign_handle = 'custom.cross_rrp'

  if mp_storefront_raw != blank
    assign mp_storefront = mp_storefront_raw | parse_json
    if mp_storefront.metafieldSource == 'linked' or mp_storefront.metafieldSource == 'custom'
      assign mp_metafield_source = 'linked'
    elsif mp_storefront.metafieldSource == 'app'
      assign mp_metafield_source = 'app'
    endif
    if mp_storefront.linkedProductMemberPrice != blank
      assign mp_product_handle = mp_storefront.linkedProductMemberPrice
    endif
    if mp_storefront.linkedVariantMemberPrice != blank
      assign mp_variant_handle = mp_storefront.linkedVariantMemberPrice
    endif
    if mp_storefront.linkedCampaign != blank
      assign mp_campaign_handle = mp_storefront.linkedCampaign
    endif
  else
    assign mp_config = metaobjects['$app:membership_config']['default']
    if mp_config == blank
      assign mp_config = shop.metaobjects['$app:membership_config']['default']
    endif
    if mp_config == blank
      assign mp_config = metaobjects.membership_config.default
    endif
    if mp_config == blank
      assign mp_config = shop.metaobjects.membership_config.default
    endif

    if mp_config != blank
      if mp_config.metafield_source.value == 'linked' or mp_config.metafield_source.value == 'custom'
        assign mp_metafield_source = 'linked'
      elsif mp_config.metafield_source.value == 'app'
        assign mp_metafield_source = 'app'
      elsif mp_config.linked_product_member_price.value != blank
        assign mp_metafield_source = 'linked'
      endif

      if mp_config.linked_product_member_price.value != blank
        assign mp_product_handle = mp_config.linked_product_member_price.value
      endif
      if mp_config.linked_variant_member_price.value != blank
        assign mp_variant_handle = mp_config.linked_variant_member_price.value
      endif
      if mp_config.linked_campaign.value != blank
        assign mp_campaign_handle = mp_config.linked_campaign.value
      endif
    endif
  endif

  assign mp_product_parts = mp_product_handle | split: '.'
  assign mp_variant_parts = mp_variant_handle | split: '.'
  assign mp_campaign_parts = mp_campaign_handle | split: '.'
  assign mp_product_ns = mp_product_parts[0]
  assign mp_product_key = mp_product_parts[1]
  assign mp_variant_ns = mp_variant_parts[0]
  assign mp_variant_key = mp_variant_parts[1]
  assign mp_campaign_ns = mp_campaign_parts[0]
  assign mp_campaign_key = mp_campaign_parts[1]

  if mp_metafield_source == 'linked'
    assign variant_member_metafield = mp_variant.metafields[mp_variant_ns][mp_variant_key]
    assign product_member_metafield = mp_product.metafields[mp_product_ns][mp_product_key]
    assign campaign_metafield = mp_product.metafields[mp_campaign_ns][mp_campaign_key]
  else
    assign variant_member_metafield = mp_variant.metafields['$app'].member_price | default: mp_variant.metafields.app.member_price
    assign product_member_metafield = mp_product.metafields['$app'].member_price | default: mp_product.metafields.app.member_price
    assign campaign_metafield = mp_product.metafields['$app'].campaign | default: mp_product.metafields.app.campaign
  endif

  assign member_metafield = variant_member_metafield | default: product_member_metafield

  assign rrp_cents = mp_variant.price
  assign member_cents = 0

  if member_metafield != blank and member_metafield.value != blank
    if member_metafield.value.amount != blank
      assign member_cents = member_metafield.value.amount | times: 100 | round
    else
      assign member_cents = member_metafield.value | money_without_currency | remove: ',' | times: 100 | round
    endif
  endif

  assign has_member_price = false
  if member_cents > 0 and rrp_cents > member_cents
    assign has_member_price = true
  endif

  assign campaign_strike = false
  if campaign_metafield.value == true
    assign campaign_strike = true
  endif

  assign savings_cents = rrp_cents | minus: member_cents
  assign currency_code = cart.currency.iso_code | default: shop.currency
-%}

{%- if layout == 'cart-line' -%}
  {%- if request.design_mode -%}
    <div class="member-pricing member-pricing--cart-line">
      <p class="member-pricing__placeholder">
        {{ 'member_pricing.cart_placeholder' | t }}
      </p>
    </div>
  {%- endif -%}
{%- elsif has_member_price or request.design_mode -%}
  <div
    class="member-pricing member-pricing--{{ layout }}"
    {% if block_id != blank %}data-member-pricing-block="{{ block_id }}"{% endif %}
    {{ shopify_attributes }}
  >
    {%- case layout -%}
      {%- when 'pdp' -%}
        {%- comment -%} PDP is rendered by blocks/member_pricing.liquid {%- endcomment -%}

      {%- when 'card' -%}
        <div class="member-pricing__prices member-pricing__prices--stacked" data-member-pricing-prices>
          <p class="member-pricing__member member-pricing__member--card">
            <span class="member-pricing__member-label">{{ member_label | escape }}</span>
            <span class="member-pricing__member-amount" data-member-pricing-member>{{ member_cents | money }}</span>
            <span class="member-pricing__currency" data-member-pricing-currency>{{ currency_code }}</span>
          </p>
          <p
            class="member-pricing__rrp{% if campaign_strike %} member-pricing__rrp--strike{% endif %}"
            data-member-pricing-rrp
            data-campaign-strike="{{ campaign_strike }}"
          >
            <span class="member-pricing__rrp-label">{{ rrp_label | escape }}</span> <span class="member-pricing__rrp-amount" data-member-pricing-rrp-amount>{{ rrp_cents | money }}</span>
          </p>
        </div>

        {%- if request.design_mode and has_member_price == false -%}
          <p class="member-pricing__placeholder">
            {{ 'member_pricing.placeholder' | t }}
          </p>
        {%- endif -%}
    {%- endcase -%}
  </div>
{%- endif -%}
