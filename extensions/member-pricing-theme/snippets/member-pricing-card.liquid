{%- comment -%}
  Product card member pricing (legacy Dawn snippet).
  Replace {% render 'price' %} in card-product.liquid with:
  {% render 'member-pricing-card', product: card_product %}
  Requires the Card pricing styles app embed for CSS.
{%- endcomment -%}

{%- liquid
  assign card_product = product | default: card_product
-%}

{%- if card_product != blank -%}
  {%- assign current_variant = card_product.selected_or_first_available_variant -%}
  <div
    class="member-pricing member-pricing--card member-pricing--card-ssr"
    data-member-pricing-card
    data-member-pricing-ssr="true"
    data-member-pricing-ready="true"
    data-product-handle="{{ card_product.handle }}"
    data-rrp-cents="{{ current_variant.price }}"
  >
    <div data-member-pricing-content>
      {% render 'member-pricing-card-inner', card_product: card_product %}
    </div>
  </div>
{%- endif -%}
