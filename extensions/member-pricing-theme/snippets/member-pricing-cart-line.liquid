{%- comment -%}
  Cart line member pricing snippet.
  Add to your theme cart line item template:
  {% render 'member-pricing-cart-line', line_item: item %}
{%- endcomment -%}

{%- liquid
  assign mp_member_label = member_label | default: 'Members'
  assign mp_rrp_label = rrp_label | default: 'RRP'
  assign mp_membership_label = membership_label | default: 'My membership'
  assign mp_login_prompt = login_prompt | default: ''
-%}

{%- render 'member-pricing-render',
  line_item: line_item,
  layout: 'cart-line',
  member_label: mp_member_label,
  rrp_label: mp_rrp_label,
  membership_label: mp_membership_label,
  login_prompt: mp_login_prompt
-%}
