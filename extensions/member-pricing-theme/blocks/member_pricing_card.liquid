{%- liquid
  assign card_product = block.settings.product | default: product | default: closest.product
-%}

{%- if card_product != blank -%}
  {%- assign current_variant = card_product.selected_or_first_available_variant -%}
  <div
    class="member-pricing member-pricing--card member-pricing--card-ssr"
    data-member-pricing-card
    data-member-pricing-ssr="true"
    data-member-pricing-ready="true"
    data-product-handle="{{ card_product.handle }}"
    data-rrp-cents="{{ current_variant.price }}"
    {{ block.shopify_attributes }}
  >
    <div data-member-pricing-content>
      {% render 'member-pricing-card-inner', card_product: card_product %}
    </div>
  </div>
{%- elsif request.design_mode -%}
  <div class="member-pricing member-pricing--card" {{ block.shopify_attributes }}>
    <p class="member-pricing__placeholder">
      Click a product card in the preview, then add this block inside that card.
    </p>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "MemberPro pricing (card)",
  "target": "section",
  "enabled_on": {
    "templates": ["index", "collection", "search", "product"]
  },
  "stylesheet": "member-pricing.css",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "autofill": true
    }
  ]
}
{% endschema %}
