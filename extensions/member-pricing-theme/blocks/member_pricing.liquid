{%- liquid
  assign block_id = block.id | default: section.id
  assign mp_member_label = 'Member price'
  assign mp_metafield_source = 'app'
  assign mp_config = shop.metaobjects.membership_config.default
  if mp_config != blank and mp_config.member_label.value != blank
    assign mp_member_label = mp_config.member_label.value
  endif
  if mp_config != blank and mp_config.metafield_source.value != blank
    assign mp_metafield_source = mp_config.metafield_source.value
  endif
  if mp_metafield_source == 'custom'
    assign mp_metafield_source = 'linked'
  endif

  assign current_variant = product.selected_or_first_available_variant
  assign rrp_cents = current_variant.price
  assign member_cents = 0
  assign member_metafield = blank

  if mp_metafield_source == 'linked'
    assign product_handle = mp_config.linked_product_member_price.value | default: 'custom.member_price'
    assign variant_handle = mp_config.linked_variant_member_price.value | default: 'custom.variant_member_price'
    assign campaign_handle = mp_config.linked_campaign.value | default: 'custom.cross_rrp'
    assign product_parts = product_handle | split: '.'
    assign variant_parts = variant_handle | split: '.'
    assign campaign_parts = campaign_handle | split: '.'
    assign product_ns = product_parts[0]
    assign product_key = product_parts[1]
    assign variant_ns = variant_parts[0]
    assign variant_key = variant_parts[1]
    assign campaign_ns = campaign_parts[0]
    assign campaign_key = campaign_parts[1]
    assign variant_member_metafield = current_variant.metafields[variant_ns][variant_key]
    assign product_member_metafield = product.metafields[product_ns][product_key]
    assign campaign_metafield = product.metafields[campaign_ns][campaign_key]
  else
    assign variant_app_metafield = current_variant.metafields['$app'].member_price
    assign variant_dot_app_metafield = current_variant.metafields.app.member_price
    assign product_app_metafield = product.metafields['$app'].member_price
    assign product_dot_app_metafield = product.metafields.app.member_price

    if variant_app_metafield != blank
      assign variant_member_metafield = variant_app_metafield
    elsif variant_dot_app_metafield != blank
      assign variant_member_metafield = variant_dot_app_metafield
    else
      assign variant_member_metafield = blank
    endif

    if product_app_metafield != blank
      assign product_member_metafield = product_app_metafield
    elsif product_dot_app_metafield != blank
      assign product_member_metafield = product_dot_app_metafield
    else
      assign product_member_metafield = blank
    endif

    assign campaign_metafield = product.metafields['$app'].campaign | default: product.metafields.app.campaign
  endif

  if variant_member_metafield != blank
    assign member_metafield = variant_member_metafield
  elsif product_member_metafield != blank
    assign member_metafield = product_member_metafield
  endif

  if member_metafield != blank and member_metafield.value != blank
    if member_metafield.value.amount != blank
      assign member_cents = member_metafield.value.amount | times: 100 | round
    elsif member_metafield.value > 0
      assign member_cents = member_metafield.value
    else
      assign member_cents = member_metafield.value | money_without_currency | remove: ',' | times: 100 | round
    endif
  endif

  assign has_member_price = false
  if member_cents > 0 and rrp_cents > member_cents
    assign has_member_price = true
  endif

  assign campaign_strike = false
  if campaign_metafield.value == true
    assign campaign_strike = true
  endif
-%}

{%- if has_member_price -%}
  <div
    class="member-pricing member-pricing--pdp"
    data-member-pricing-block="{{ block_id }}"
    {{ block.shopify_attributes }}
  >
    <div class="member-pricing__prices" data-member-pricing-prices>
      <span class="member-pricing__member">
        <span class="member-pricing__member-label">{{ mp_member_label | escape }}</span>
        <span class="member-pricing__member-amount" data-member-pricing-member>{{ member_cents | money }}</span>
      </span>
      <span
        class="member-pricing__rrp{% if campaign_strike %} member-pricing__rrp--strike{% endif %}"
        data-member-pricing-rrp
        data-campaign-strike="{{ campaign_strike }}"
      >
        <span class="member-pricing__rrp-label">RRP</span> <span class="member-pricing__rrp-amount" data-member-pricing-rrp-amount>{{ rrp_cents | money }}</span>
      </span>
    </div>

    <p class="member-pricing__login-hint" data-member-pricing-login-hint>
      <span class="member-pricing__login-icon" aria-hidden="true">&#128161;</span>
      To get this product at member price, please
      <a href="{{ routes.account_login_url }}?return_url={{ request.path | url_encode }}">login</a>
      to your account first.
    </p>
  </div>

  <script type="application/json" data-member-pricing-variants="{{ block_id }}">
    {
      "moneyFormat": {{ shop.money_format | json }},
      "variants": [
        {%- for variant in product.variants -%}
          {%- liquid
            if mp_metafield_source == 'linked'
              assign v_member_metafield = variant.metafields[variant_ns][variant_key] | default: product.metafields[product_ns][product_key]
              assign v_campaign = product.metafields[campaign_ns][campaign_key].value
            else
              assign v_member_metafield = variant.metafields['$app'].member_price | default: product.metafields['$app'].member_price
              assign v_campaign = product.metafields['$app'].campaign.value
            endif
            assign v_member_cents = 0
            if v_member_metafield != blank and v_member_metafield.value != blank
              if v_member_metafield.value.amount != blank
                assign v_member_cents = v_member_metafield.value.amount | times: 100 | round
              else
                assign v_member_cents = v_member_metafield.value | money_without_currency | remove: ',' | times: 100 | round
              endif
            endif
          -%}
          {
            "id": {{ variant.id | json }},
            "rrpCents": {{ variant.price }},
            "memberCents": {{ v_member_cents }},
            "campaignStrike": {{ v_campaign | default: false | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- elsif request.design_mode -%}
  <div
    class="member-pricing member-pricing--pdp"
    data-member-pricing-block="{{ block_id }}"
    {{ block.shopify_attributes }}
  >
    <p class="member-pricing__placeholder">
      Member pricing appears here when a product or variant has a Member price metafield lower than the regular price.
    </p>
  </div>
{%- else -%}
  <div class="member-pricing member-pricing--pdp member-pricing--pdp-fallback" {{ block.shopify_attributes }}>
    <p class="member-pricing__regular-only">
      <span class="member-pricing__regular-amount">{{ current_variant.price | money }}</span>
    </p>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "MemberPro pricing",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "stylesheet": "member-pricing.css",
  "javascript": "member-pricing-pdp.js",
  "settings": [
    {
      "type": "text",
      "id": "membership_label",
      "label": "Membership label",
      "default": "My membership"
    }
  ]
}
{% endschema %}
