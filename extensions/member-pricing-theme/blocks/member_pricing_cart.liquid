{%- comment -%}
  Cart template helper — not required for pricing display.
  Logged-in customers see member savings via the automatic MemberPro discount
  (strikethrough price + savings line text from app settings).
{%- endcomment -%}

{%- if request.design_mode -%}
  <div class="member-pricing-cart-block" {{ block.shopify_attributes }}>
    <p class="member-pricing__placeholder">{{ 'member_pricing.cart_block_placeholder' | t }}</p>
    <p class="member-pricing__placeholder">{{ 'member_pricing.cart_design_hint' | t }}</p>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "MemberPro pricing (cart)",
  "target": "section",
  "enabled_on": {
    "templates": ["cart"]
  },
  "stylesheet": "member-pricing.css",
  "settings": [
    {
      "type": "paragraph",
      "content": "Member cart pricing is handled by the automatic MemberPro discount. Enable Card pricing styles under App embeds so the cart drawer hides duplicate totals."
    }
  ]
}
{% endschema %}
