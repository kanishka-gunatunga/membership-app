{%- comment -%}
  Loads CSS + optional JS fallback for dynamically injected product cards.
  Enable under Theme settings → App embeds → Card pricing styles.
{%- endcomment -%}

{% schema %}
{
  "name": "Card pricing styles",
  "target": "body",
  "stylesheet": "member-pricing.css",
  "javascript": "member-pricing-cards.js",
  "settings": [
    {
      "type": "paragraph",
      "content": "Required for product card member pricing on collection pages. Prices render in HTML on page load; JS only hydrates cards added later (e.g. carousels). Hard-refresh after enabling."
    }
  ]
}
{% endschema %}
