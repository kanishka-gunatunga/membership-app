{%- comment -%}
  Loads CSS + JS for product card member pricing hydration.
  Enable under Theme settings → App embeds → Card pricing styles.
{%- endcomment -%}

{% schema %}
{
  "name": "Card pricing styles",
  "target": "body",
  "stylesheet": "member-pricing.css",
  "javascript": "member-pricing-cards.js",
  "settings": [
    {
      "type": "paragraph",
      "content": "Required for product card member pricing on collection pages. Enable on all pages, then hard-refresh."
    }
  ]
}
{% endschema %}
